<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f0c29"
    android:padding="16dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_title_icon"
            android:gravity="center"
            android:text="D"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DUDOU AI"
                android:textColor="#ffffff"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CDKey 授权码生成器"
                android:textColor="#cccccc"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#222233"
        android:layout_marginBottom="12dp"/>

    <!-- 生成设置卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111122"
        android:padding="14dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="生成设置"
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222233"
            android:layout_marginBottom="10dp"/>

        <!-- 授权类型 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="授权类型"
                android:textColor="#cccccc"
                android:textSize="13sp"/>

            <Spinner
                android:id="@+id/spType"
                android:layout_width="200dp"
                android:layout_height="40dp"
                android:background="#1a1a2e"
                android:popupBackground="#1a1a2e"/>
        </LinearLayout>

        <!-- 最大激活数 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="最大激活数"
                android:textColor="#cccccc"
                android:textSize="13sp"/>

            <EditText
                android:id="@+id/etMaxAct"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:background="#1a1a2e"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:gravity="center"
                android:inputType="number"
                android:padding="8dp"
                android:maxLines="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  （0=无限制）"
                android:textColor="#888888"
                android:textSize="11sp"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <!-- 生成数量 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="生成数量"
                android:textColor="#cccccc"
                android:textSize="13sp"/>

            <EditText
                android:id="@+id/etCount"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:background="#1a1a2e"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:gravity="center"
                android:inputType="number"
                android:padding="8dp"
                android:maxLines="1"/>
        </LinearLayout>

        <!-- 生成按钮 -->
        <Button
            android:id="@+id/btnGenerate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#a855f7"
            android:text="✨ 生成 CDKey"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- 生成结果卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#111122"
        android:padding="14dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="生成结果"
            android:textColor="#ffffff"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#222233"
            android:layout_marginBottom="10dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0d0d1a"
                android:textColor="#a78bfa"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:padding="12dp"
                android:lineSpacingExtra="4dp"/>
        </ScrollView>

        <!-- 操作栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="就绪 — 请选择参数后点击「生成 CDKey」"
                android:textColor="#888888"
                android:textSize="11sp"/>

            <Button
                android:id="@+id/btnCopy"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="#222233"
                android:text="📋 复制"
                android:textColor="#cccccc"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="#222233"
                android:text="💾 保存"
                android:textColor="#cccccc"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 底部版本号 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DUDOU AI · CDKey Generator v1.0"
        android:textColor="#444444"
        android:textSize="10sp"
        android:gravity="end"/>

</LinearLayout>
